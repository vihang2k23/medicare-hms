# Optional: JSON Server origin only — no path (default http://localhost:3001 in dev).
# REST: {origin}/api/patients, /api/vitals, /api/internalDoctors, /api/npi (NPI proxy).
# VITE_JSON_SERVER_URL=http://localhost:3001
# Render (single Web service in render.yaml): leave unset so the app uses same-origin /api/...

# Optional: openFDA (defaults match public API — see https://api.fda.gov/drug/label.json )
# VITE_OPENFDA_DRUG_LABEL_URL=https://api.fda.gov/drug/label.json
# VITE_OPENFDA_DRUG_ENFORCEMENT_URL=https://api.fda.gov/drug/enforcement.json
